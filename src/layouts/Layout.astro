---
interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
}

const { title, description = "Your AI agent's hall of glory. Running in one command.", canonicalURL } = Astro.props;
const siteURL = 'https://clawhalla.xyz';
const canonical = canonicalURL || new URL(Astro.url.pathname, siteURL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0D0D0D" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteURL}/og-image.png`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ClawHalla" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteURL}/og-image.png`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ClawHalla",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Linux, macOS, Windows (Docker)",
      "description": "Enterprise Autonomous AI Operating System. Open source, self-hosted multi-agent platform with Mission Control dashboard.",
      "url": siteURL,
      "downloadUrl": `${siteURL}/install.sh`,
      "license": "https://github.com/deegalabs/clawhalla/blob/main/LICENSE",
      "author": {
        "@type": "Organization",
        "name": "Deega Labs",
        "url": "https://github.com/deegalabs"
      },
      "offers": [
        {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD",
          "description": "Free tier — open source, self-hosted"
        },
        {
          "@type": "Offer",
          "price": "49",
          "priceCurrency": "USD",
          "description": "Pro tier — all 15 agents, premium packs, priority support"
        }
      ]
    })} />
  </head>
  <body class="bg-dark text-gray-200 font-sans">
    <!-- Navigation -->
    <input type="checkbox" id="nav-toggle" class="nav-toggle-checkbox" />
    <nav class="fixed top-0 left-0 right-0 z-50 bg-dark/80 backdrop-blur-md border-b border-dark-200">
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 shrink-0">
          <span class="text-xl">&#x1F99E;</span>
          <span class="font-heading text-lg font-bold">
            <span class="text-primary">Claw</span><span class="text-gray-100">Halla</span>
          </span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-8">
          <a href="/#features" class="text-sm text-gray-400 hover:text-primary transition-colors">Features</a>
          <a href="/docs" class="text-sm text-gray-400 hover:text-primary transition-colors">Docs</a>
          <a href="/pricing" class="text-sm text-gray-400 hover:text-primary transition-colors">Pricing</a>
          <a href="/changelog" class="text-sm text-gray-400 hover:text-primary transition-colors">Changelog</a>
          <a href="/community" class="text-sm text-gray-400 hover:text-primary transition-colors">Community</a>
        </div>

        <!-- GitHub + hamburger -->
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/deegalabs/clawhalla"
            target="_blank"
            rel="noopener"
            class="text-gray-400 hover:text-primary transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>

          <!-- Mobile hamburger -->
          <label for="nav-toggle" class="md:hidden cursor-pointer text-gray-400 hover:text-primary transition-colors" aria-label="Toggle menu">
            <svg class="hamburger-icon w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
            <svg class="close-icon w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
          </label>
        </div>
      </div>

      <!-- Mobile menu -->
      <div class="mobile-menu md:hidden border-t border-dark-200">
        <div class="px-4 py-4 flex flex-col gap-4 bg-dark-50">
          <a href="/#features" class="text-sm text-gray-400 hover:text-primary transition-colors">Features</a>
          <a href="/docs" class="text-sm text-gray-400 hover:text-primary transition-colors">Docs</a>
          <a href="/pricing" class="text-sm text-gray-400 hover:text-primary transition-colors">Pricing</a>
          <a href="/changelog" class="text-sm text-gray-400 hover:text-primary transition-colors">Changelog</a>
          <a href="/community" class="text-sm text-gray-400 hover:text-primary transition-colors">Community</a>
        </div>
      </div>
    </nav>

    <!-- Spacer for fixed nav -->
    <div class="h-16"></div>

    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* Mobile nav toggle — CSS only */
  .nav-toggle-checkbox {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .close-icon {
    display: none;
  }

  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .nav-toggle-checkbox:checked ~ nav .mobile-menu {
    max-height: 24rem;
  }

  .nav-toggle-checkbox:checked ~ nav .hamburger-icon {
    display: none;
  }

  .nav-toggle-checkbox:checked ~ nav .close-icon {
    display: block;
  }
</style>
