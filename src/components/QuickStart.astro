---
// Quick Start — full install flow with animated terminal
---

<section id="quick-start" class="py-20 sm:py-28 px-4 bg-dark">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-4">
      <span class="text-primary">Quick</span> Start
    </h2>
    <p class="text-gray-400 text-center mb-12 max-w-xl mx-auto">
      Three steps. Five minutes. Works with Docker or directly on Ubuntu/Linux.
    </p>

    <!-- Steps -->
    <div class="space-y-6 mb-12">
      <!-- Step 1 -->
      <div class="flex items-start gap-4">
        <span class="shrink-0 w-8 h-8 rounded-full bg-primary text-dark text-sm font-bold flex items-center justify-center mt-1">1</span>
        <div class="flex-1">
          <h3 class="font-heading text-lg font-bold text-gray-100 mb-3">Install ClawHalla</h3>
          <div class="bg-dark-50 rounded-xl border border-dark-200 overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-2.5 bg-dark-100 border-b border-dark-200">
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
              </div>
              <span class="ml-2 text-gray-500 text-xs font-mono">terminal</span>
            </div>
            <div class="p-4 font-mono text-sm">
              <div class="flex items-center gap-2">
                <span class="text-green-400">$</span>
                <code class="text-gray-200 flex-1">curl -fsSL https://clawhalla.xyz/install.sh | bash</code>
                <button class="copy-btn p-1.5 text-gray-500 hover:text-primary transition-colors" data-copy="curl -fsSL https://clawhalla.xyz/install.sh | bash">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
          <p class="text-gray-500 text-xs mt-2">Works on Ubuntu/Linux. Installs Docker if needed.</p>
          <details class="mt-3">
            <summary class="text-gray-400 text-xs cursor-pointer hover:text-primary transition-colors">Or install directly on OS (no Docker)</summary>
            <div class="bg-dark-50 rounded-xl border border-dark-200 overflow-hidden mt-2">
              <div class="p-4 font-mono text-sm space-y-1">
                <div class="flex items-center gap-2">
                  <span class="text-green-400">$</span>
                  <code class="text-gray-200">git clone https://github.com/deegalabs/clawhalla.git</code>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-green-400">$</span>
                  <code class="text-gray-200">cd clawhalla && ./setup.sh</code>
                </div>
              </div>
            </div>
          </details>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="flex items-start gap-4">
        <span class="shrink-0 w-8 h-8 rounded-full bg-primary text-dark text-sm font-bold flex items-center justify-center mt-1">2</span>
        <div class="flex-1">
          <h3 class="font-heading text-lg font-bold text-gray-100 mb-3">Follow the Wizard</h3>
          <div class="bg-dark-50 rounded-xl border border-dark-200 overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-2.5 bg-dark-100 border-b border-dark-200">
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
              </div>
              <span class="ml-2 text-gray-500 text-xs font-mono">clawhalla-setup</span>
            </div>
            <div class="p-4 font-mono text-sm space-y-2">
              <p><span class="text-primary">?</span> <span class="text-gray-300">Auth method:</span> <span class="text-green-400">Claude Max OAuth</span></p>
              <p><span class="text-primary">?</span> <span class="text-gray-300">Default model:</span> <span class="text-green-400">claude-opus-4-6</span></p>
              <p><span class="text-primary">?</span> <span class="text-gray-300">Choose 3 agents:</span> <span class="text-green-400">Odin, Frigg, Freya</span></p>
              <p><span class="text-primary">?</span> <span class="text-gray-300">Mission Control port:</span> <span class="text-green-400">3000</span></p>
              <p class="text-gray-500 mt-3"><span class="text-green-400">&#10003;</span> Configuration saved to .env</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex items-start gap-4">
        <span class="shrink-0 w-8 h-8 rounded-full bg-primary text-dark text-sm font-bold flex items-center justify-center mt-1">3</span>
        <div class="flex-1">
          <h3 class="font-heading text-lg font-bold text-gray-100 mb-3">Open Mission Control</h3>
          <div class="bg-dark-50 rounded-xl border border-dark-200 overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-2.5 bg-dark-100 border-b border-dark-200">
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
              </div>
              <span class="ml-2 text-gray-500 text-xs font-mono">browser</span>
            </div>
            <div class="p-4 font-mono text-sm space-y-2">
              <p><span class="text-green-400">&#10003;</span> <span class="text-gray-300">4 starter agents online</span></p>
              <p><span class="text-green-400">&#10003;</span> <span class="text-gray-300">Mission Control active</span></p>
              <p><span class="text-green-400">&#10003;</span> <span class="text-gray-300">Mission Control ready at</span> <span class="text-primary">http://localhost:3000</span></p>
              <p class="mt-3 text-gray-500 text-xs">Open your browser and start commanding your AI workforce.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy;
      navigator.clipboard.writeText(text || '');

      btn.innerHTML = '<svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
      setTimeout(() => {
        btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>';
      }, 2000);
    });
  });
</script>
