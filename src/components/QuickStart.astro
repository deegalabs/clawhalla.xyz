---
// Quick Start terminal component
---

<section id="quick-start" class="py-20 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-4">
      <span class="text-primary">❯</span> Quick Start
    </h2>
    <p class="text-gray-400 text-center mb-10">
      From zero to running agent in under 5 minutes.
    </p>

    <div class="bg-dark-50 rounded-xl border border-dark-200 overflow-hidden shadow-2xl">
      <div class="flex items-center gap-2 px-4 py-3 bg-dark-100 border-b border-dark-200">
        <div class="flex gap-2">
          <span class="w-3 h-3 rounded-full bg-red-500"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
          <span class="w-3 h-3 rounded-full bg-green-500"></span>
        </div>
        <span class="ml-4 text-gray-500 text-sm font-mono">bash</span>

        <div class="ml-auto flex gap-2">
          <button class="tab-btn active px-3 py-1 text-sm rounded bg-dark-200 text-primary" data-tab="one-liner">
            One-liner
          </button>
          <button class="tab-btn px-3 py-1 text-sm rounded text-gray-400 hover:text-gray-200" data-tab="manual">
            Manual
          </button>
        </div>
      </div>

      <div class="p-6 font-mono text-sm">
        <div id="tab-one-liner" class="tab-content">
          <p class="text-gray-500 mb-2"># Works on macOS and Linux. Installs Docker if needed.</p>
          <div class="flex items-center gap-2">
            <span class="text-green-400">$</span>
            <code class="text-gray-200 flex-1">curl -fsSL https://clawhalla.xyz/install.sh | bash</code>
            <button class="copy-btn p-2 text-gray-500 hover:text-primary transition-colors" data-copy="curl -fsSL https://clawhalla.xyz/install.sh | bash">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </button>
          </div>
        </div>

        <div id="tab-manual" class="tab-content hidden">
          <p class="text-gray-500 mb-4"># Step by step installation</p>

          <div class="space-y-4">
            <div>
              <p class="text-gray-500 text-xs mb-1"># Clone the repository</p>
              <div class="flex items-center gap-2">
                <span class="text-green-400">$</span>
                <code class="text-gray-200">git clone https://github.com/deegalabs/clawhalla.git</code>
              </div>
            </div>

            <div>
              <p class="text-gray-500 text-xs mb-1"># Enter directory and configure</p>
              <div class="flex items-center gap-2">
                <span class="text-green-400">$</span>
                <code class="text-gray-200">cd clawhalla && cp .env.example .env</code>
              </div>
            </div>

            <div>
              <p class="text-gray-500 text-xs mb-1"># Add your Anthropic API key to .env, then start</p>
              <div class="flex items-center gap-2">
                <span class="text-green-400">$</span>
                <code class="text-gray-200">bash scripts/start.sh</code>
              </div>
            </div>

            <div>
              <p class="text-gray-500 text-xs mb-1"># Enter the container and run onboard</p>
              <div class="flex items-center gap-2">
                <span class="text-green-400">$</span>
                <code class="text-gray-200">docker compose exec clawhalla bash</code>
              </div>
              <div class="flex items-center gap-2 mt-1">
                <span class="text-blue-400">clawdbot@container:~$</span>
                <code class="text-gray-200">openclaw onboard</code>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <p class="text-center text-gray-500 text-sm mt-4">
      Works on macOS and Linux. Windows support coming soon via WSL2.
    </p>
  </div>
</section>

<script>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;

      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('active', 'bg-dark-200', 'text-primary');
        b.classList.add('text-gray-400');
      });
      btn.classList.add('active', 'bg-dark-200', 'text-primary');
      btn.classList.remove('text-gray-400');

      document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
      document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
    });
  });

  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy;
      navigator.clipboard.writeText(text || '');

      btn.innerHTML = '<svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
      setTimeout(() => {
        btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>';
      }, 2000);
    });
  });
</script>
