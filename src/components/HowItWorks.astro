---
const steps = [
  {
    num: '01',
    title: 'Install',
    description: 'One command installs Docker, OpenClaw, 15 agents, and Mission Control.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 8h10M7 12h6M7 16h8"/></svg>`,
  },
  {
    num: '02',
    title: 'Configure',
    description: 'Claude Max OAuth or API key. Choose your model. Set your goals.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.32 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>`,
  },
  {
    num: '03',
    title: 'Deploy',
    description: 'Agents start working autonomously. Monitor everything from Mission Control.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>`,
  },
];
---

<section class="py-20 sm:py-28 px-4 bg-dark relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-dark-50/50 via-transparent to-dark-50/50 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-4">
      <span class="text-primary">How It</span> Works
    </h2>
    <p class="text-gray-400 text-center mb-16 max-w-2xl mx-auto">
      From zero to a fully autonomous AI workforce in under five minutes.
    </p>

    <div class="grid md:grid-cols-3 gap-8 md:gap-6 relative">
      <!-- Connecting lines (desktop only) -->
      <div class="hidden md:block absolute top-16 left-[calc(33.33%+0.75rem)] right-[calc(33.33%+0.75rem)] h-px">
        <div class="w-full h-px bg-gradient-to-r from-primary/60 via-primary/30 to-primary/60"></div>
      </div>

      {steps.map((step) => (
        <div class="relative flex flex-col items-center text-center group">
          <div class="w-32 h-32 rounded-2xl bg-dark-50 border border-dark-200 group-hover:border-primary/40 transition-all duration-300 flex flex-col items-center justify-center mb-6 relative">
            <span class="absolute -top-3 -right-3 w-8 h-8 rounded-full bg-primary text-dark text-sm font-bold flex items-center justify-center shadow-lg shadow-primary/20">
              {step.num}
            </span>
            <div class="text-primary" set:html={step.icon} />
          </div>
          <h3 class="font-heading text-xl font-bold text-gray-100 mb-3">{step.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed max-w-xs">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
