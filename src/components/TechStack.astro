---
const technologies = [
  { name: 'Claude AI', icon: 'AI' },
  { name: 'OpenClaw', icon: 'OC' },
  { name: 'Docker', icon: 'DK' },
  { name: 'Next.js', icon: 'NX' },
  { name: 'SQLite', icon: 'SQ' },
  { name: 'Base L2', icon: 'B2' },
  { name: 'Solidity', icon: 'SO' },
  { name: 'Tailwind', icon: 'TW' },
];
---

<section class="py-16 sm:py-20 px-4 bg-dark border-t border-dark-200">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-gray-500 text-sm uppercase tracking-widest font-medium mb-10">
      Built With
    </p>

    <div class="flex flex-wrap justify-center gap-6 sm:gap-10">
      {technologies.map((tech) => (
        <div class="group flex flex-col items-center gap-2 transition-all">
          <div class="w-14 h-14 rounded-xl bg-dark-50 border border-dark-200 group-hover:border-primary/30 transition-all flex items-center justify-center">
            <span class="text-sm font-mono font-bold text-gray-400 group-hover:text-primary transition-colors">{tech.icon}</span>
          </div>
          <span class="text-xs text-gray-500 group-hover:text-gray-300 transition-colors">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
