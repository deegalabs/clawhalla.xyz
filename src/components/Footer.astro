---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 px-4 border-t border-dark-200">
  <div class="max-w-4xl mx-auto text-center">
    <div class="flex justify-center gap-6 mb-6">
      <a href="https://github.com/deegalabs/clawhalla" class="text-gray-400 hover:text-primary transition-colors">
        GitHub
      </a>
      <a href="/docs" class="text-gray-400 hover:text-primary transition-colors">
        Documentation
      </a>
      <a href="https://openclaw.ai" class="text-gray-400 hover:text-primary transition-colors">
        OpenClaw
      </a>
    </div>

    <p class="text-gray-500 text-sm mb-2">
      Built for the OpenClaw community by <a href="https://github.com/deegalabs" class="text-primary hover:underline">DeegaLabs</a>
    </p>

    <p class="text-gray-600 text-xs">MIT License © {currentYear} ClawHalla Contributors</p>
  </div>
</footer>
