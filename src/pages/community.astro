---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const links = [
  {
    title: 'GitHub',
    description: 'Source code, issues, and pull requests. Star the repo to show your support.',
    href: 'https://github.com/deegalabs/clawhalla',
    icon: 'github',
    color: 'from-gray-600 to-gray-800',
  },
  {
    title: 'Discord',
    description: 'Chat with the community, ask questions, share your builds, and get help.',
    href: '#',
    icon: 'discord',
    color: 'from-indigo-600 to-indigo-800',
  },
  {
    title: 'Twitter / X',
    description: 'Follow for release announcements, tips, and project updates.',
    href: '#',
    icon: 'twitter',
    color: 'from-sky-600 to-sky-800',
  },
  {
    title: 'LinkedIn',
    description: 'Professional updates, project news, and developer resources.',
    href: '#',
    icon: 'linkedin',
    color: 'from-blue-600 to-blue-800',
  },
];

const showcaseProjects = [
  { name: 'Your Project Here', description: 'Submit your ClawHalla-powered project to be featured.', link: '#' },
];
---

<Layout title="Community — ClawHalla" description="Join the ClawHalla community. Contribute, build, and connect with developers building autonomous AI systems.">
  <main>
    <!-- Hero -->
    <section class="py-20 sm:py-28 px-4 bg-dark relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent pointer-events-none"></div>
      <div class="max-w-4xl mx-auto text-center relative">
        <h1 class="font-heading text-4xl md:text-5xl font-bold mb-6">
          Join the <span class="text-primary">ClawHalla</span> Community
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          ClawHalla is built by developers, for developers. Join the growing community building the future of autonomous AI systems.
        </p>
      </div>
    </section>

    <!-- Links grid -->
    <section class="py-16 px-4 bg-dark-50">
      <div class="max-w-5xl mx-auto">
        <div class="grid sm:grid-cols-2 gap-6">
          {links.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener' : undefined}
              class="group block rounded-xl border border-dark-200 bg-dark p-6 hover:border-primary/40 transition-all hover:shadow-lg hover:shadow-primary/5"
            >
              <div class="flex items-start gap-4">
                <div class={`w-12 h-12 rounded-lg bg-gradient-to-br ${link.color} flex items-center justify-center shrink-0`}>
                  {link.icon === 'github' && (
                    <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                  )}
                  {link.icon === 'discord' && (
                    <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
                  )}
                  {link.icon === 'twitter' && (
                    <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  )}
                  {link.icon === 'linkedin' && (
                    <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  )}
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-gray-100 group-hover:text-primary transition-colors mb-1">{link.title}</h3>
                  <p class="text-sm text-gray-400">{link.description}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Contributors -->
    <section class="py-20 px-4 bg-dark">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">
            Built by <span class="text-primary">Deega Labs</span>
          </h2>
          <p class="text-gray-400 max-w-2xl mx-auto">
            ClawHalla is created and maintained by Deega Labs and the open source community.
            Every contribution matters — from code to documentation to feedback.
          </p>
        </div>

        <div class="grid sm:grid-cols-3 gap-6">
          <!-- Contribute -->
          <div class="rounded-xl border border-dark-200 bg-dark-50 p-6">
            <div class="text-2xl mb-3">&#x1F4BB;</div>
            <h3 class="font-semibold text-gray-100 mb-2">Contribute Code</h3>
            <p class="text-sm text-gray-400 mb-4">
              Fix bugs, add features, or improve performance. Check out our contributing guide to get started.
            </p>
            <a
              href="https://github.com/deegalabs/clawhalla/blob/main/CONTRIBUTING.md"
              target="_blank"
              rel="noopener"
              class="text-sm text-primary hover:underline"
            >
              CONTRIBUTING.md &rarr;
            </a>
          </div>

          <!-- Squad packs -->
          <div class="rounded-xl border border-dark-200 bg-dark-50 p-6">
            <div class="text-2xl mb-3">&#x1F4E6;</div>
            <h3 class="font-semibold text-gray-100 mb-2">Submit Squad Packs</h3>
            <p class="text-sm text-gray-400 mb-4">
              Create agent personas and skill packs. Share them with the community on GitHub.
            </p>
            <a
              href="https://github.com/deegalabs/clawhalla/blob/main/docs/packs.md"
              target="_blank"
              rel="noopener"
              class="text-sm text-primary hover:underline"
            >
              Pack Guide &rarr;
            </a>
          </div>

          <!-- Feedback -->
          <div class="rounded-xl border border-dark-200 bg-dark-50 p-6">
            <div class="text-2xl mb-3">&#x1F4AC;</div>
            <h3 class="font-semibold text-gray-100 mb-2">Report & Discuss</h3>
            <p class="text-sm text-gray-400 mb-4">
              Found a bug? Have an idea? Open an issue or join the discussion on GitHub.
            </p>
            <a
              href="https://github.com/deegalabs/clawhalla/issues"
              target="_blank"
              rel="noopener"
              class="text-sm text-primary hover:underline"
            >
              Open an Issue &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Built with ClawHalla -->
    <section class="py-20 px-4 bg-dark-50">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">
          Built with <span class="text-primary">ClawHalla</span>
        </h2>
        <p class="text-gray-400 mb-12 max-w-2xl mx-auto">
          Showcase of projects and teams using ClawHalla. Want to be featured? Submit your project.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {showcaseProjects.map((project) => (
            <div class="rounded-xl border border-dashed border-dark-300 bg-dark/50 p-8 flex flex-col items-center justify-center text-center min-h-[180px]">
              <div class="text-3xl text-gray-600 mb-3">+</div>
              <h3 class="text-gray-400 font-medium mb-1">{project.name}</h3>
              <p class="text-sm text-gray-500">{project.description}</p>
            </div>
          ))}
          <div class="rounded-xl border border-dashed border-dark-300 bg-dark/50 p-8 flex flex-col items-center justify-center text-center min-h-[180px]">
            <div class="text-3xl text-gray-600 mb-3">+</div>
            <h3 class="text-gray-400 font-medium mb-1">Submit Your Project</h3>
            <p class="text-sm text-gray-500">
              <a href="https://github.com/deegalabs/clawhalla/issues/new?title=Showcase:%20My%20Project" target="_blank" rel="noopener" class="text-primary hover:underline">
                Open an issue
              </a> to be featured.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 px-4 bg-dark text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold mb-4">
          Start <span class="text-primary">Building</span> Today
        </h2>
        <p class="text-gray-400 mb-8">
          One command to deploy. A whole community to build with.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/#quick-start"
            class="px-8 py-3 bg-primary text-dark font-semibold rounded-lg hover:bg-primary-300 transition-all hover:shadow-lg hover:shadow-primary/25"
          >
            Get Started
          </a>
          <a
            href="https://github.com/deegalabs/clawhalla"
            target="_blank"
            rel="noopener"
            class="px-8 py-3 border border-primary/40 text-primary rounded-lg hover:bg-primary/10 transition-all font-semibold"
          >
            Star on GitHub
          </a>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
